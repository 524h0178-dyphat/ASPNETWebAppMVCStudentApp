@model IEnumerable<ASPNETWebAppMVCStudentApp.Student>

@{
    ViewBag.Title = "Student Management";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-primary">
            <i class="glyphicon glyphicon-education"></i> Student List
        </h2>
        @Html.ActionLink("Add New Student", "Create", null, new { @class = "btn btn-success shadow-sm" })
    </div>

    <div class="card shadow border-0">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">Academic Records: Students</h4>
        </div>
        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Full Name</th>
                        <th class="text-center">@Html.DisplayNameFor(model => model.EnrollmentDate)</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="align-middle ps-4">
                                <span class="fw-bold text-dark">
                                    @item.FirstName @item.LastName
                                </span>
                            </td>
                            <td class="text-center align-middle">
                                <i class="glyphicon glyphicon-calendar text-muted me-1"></i>
                                @item.EnrollmentDate.ToString("dd/MM/yyyy")
                            </td>
                            <td class="text-center align-middle">
                                <div class="btn-group" role="group">
                                    @Html.ActionLink("Edit", "Edit", new { id = item.StudentID }, new { @class = "btn btn-outline-primary btn-sm" })
                                    @Html.ActionLink("Details", "Details", new { id = item.StudentID }, new { @class = "btn btn-outline-info btn-sm" })
                                    @Html.ActionLink("Delete", "Delete", new { id = item.StudentID }, new { @class = "btn btn-outline-danger btn-sm" })
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>