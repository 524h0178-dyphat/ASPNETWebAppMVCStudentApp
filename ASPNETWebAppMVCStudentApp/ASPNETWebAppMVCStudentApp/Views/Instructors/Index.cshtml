@model IEnumerable<ASPNETWebAppMVCStudentApp.Instructor>

@{
    ViewBag.Title = "Instructor Management";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-primary">
            <i class="glyphicon glyphicon-user"></i> Instructor List
        </h2>
        @Html.ActionLink("Add New Instructor", "Create", null, new { @class = "btn btn-success shadow-sm" })
    </div>

    <div class="card shadow border-0">
        <div class="card-header bg-info text-white">
            <h4 class="mb-0"><i class="glyphicon glyphicon-list-alt"></i> Faculty Staff</h4>
        </div>
        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Full Name</th>
                        <th class="text-center">@Html.DisplayNameFor(model => model.HireDate)</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="align-middle ps-4">
                                <span class="fw-bold text-dark">
                                    @item.FirstName @item.LastName
                                </span>
                            </td>
                            <td class="text-center align-middle">
                                <span class="text-muted">
                                    <i class="glyphicon glyphicon-calendar"></i>
                                    @item.HireDate.ToString("dd MMM yyyy")
                                </span>
                            </td>
                            <td class="text-center align-middle">
                                <div class="btn-group" role="group">
                                    @Html.ActionLink("Edit", "Edit", new { id = item.InstructorID }, new { @class = "btn btn-outline-primary btn-sm" })
                                    @Html.ActionLink("Details", "Details", new { id = item.InstructorID }, new { @class = "btn btn-outline-info btn-sm" })
                                    @Html.ActionLink("Delete", "Delete", new { id = item.InstructorID }, new { @class = "btn btn-outline-danger btn-sm" })
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>