@model IEnumerable<ASPNETWebAppMVCStudentApp.Department>

@{
    ViewBag.Title = "Department Management";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-primary">
            <i class="glyphicon glyphicon-th-list"></i> Department List
        </h2>
        @Html.ActionLink("Create New Department", "Create", null, new { @class = "btn btn-success shadow-sm" })
    </div>

    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">Department Information</h4>
        </div>
        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">@Html.DisplayNameFor(model => model.Name)</th>
                        <th>@Html.DisplayNameFor(model => model.Budget)</th>
                        <th>@Html.DisplayNameFor(model => model.StartDate)</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="align-middle ps-4 fw-bold text-dark">
                                @Html.DisplayFor(modelItem => item.Name)
                            </td>
                            <td class="align-middle">
                                <span class="text-success fw-bold">
                                    @String.Format("{0:C}", item.Budget)
                                </span>
                            </td>
                            <td class="align-middle">
                                @item.StartDate.ToString("dd/MM/yyyy")
                            </td>
                            <td class="text-center align-middle">
                                <div class="btn-group" role="group">
                                    @Html.ActionLink("Edit", "Edit", new { id = item.DepartmentID }, new { @class = "btn btn-outline-primary btn-sm" })
                                    @Html.ActionLink("Details", "Details", new { id = item.DepartmentID }, new { @class = "btn btn-outline-info btn-sm" })
                                    @Html.ActionLink("Delete", "Delete", new { id = item.DepartmentID }, new { @class = "btn btn-outline-danger btn-sm" })
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>